{
  "name": "@xevion/tempo",
  "version": "0.1.0",
  "type": "module",
  "description": "Consolidated Bun-based developer scripts with composable primitives and config-driven runners",
  "author": "Xevion",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Xevion/tempo.git"
  },
  "bin": {
    "tempo": "./src/cli.ts"
  },
  "exports": {
    ".": { "bun": "./src/index.ts" },
    "./proc": { "bun": "./src/proc.ts" },
    "./fmt": { "bun": "./src/fmt.ts" },
    "./preflight": { "bun": "./src/preflight.ts" },
    "./targets": { "bun": "./src/targets.ts" },
    "./watch": { "bun": "./src/watch.ts" },
    "./octocov": { "bun": "./src/octocov.ts" }
  },
  "files": [
    "src/"
  ],
  "dependencies": {
    "cleye": "^2.3.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0"
  }
}
