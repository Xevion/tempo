{
  "name": "@xevion/tempo",
  "version": "0.1.0",
  "type": "module",
  "description": "Consolidated Bun-based developer scripts with composable primitives and config-driven runners",
  "author": "Xevion",
  "license": "LGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/Xevion/tempo.git"
  },
  "bin": {
    "tempo": "./src/cli.ts"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts"
    },
    "./proc": {
      "bun": "./src/proc.ts"
    },
    "./fmt": {
      "bun": "./src/fmt.ts"
    },
    "./preflight": {
      "bun": "./src/preflight.ts"
    },
    "./targets": {
      "bun": "./src/targets.ts"
    },
    "./watch": {
      "bun": "./src/watch.ts"
    },
    "./octocov": {
      "bun": "./src/octocov.ts"
    }
  },
  "files": [
    "src/"
  ],
  "dependencies": {
    "@catppuccin/palette": "^1.8.0",
    "@logtape/file": "^2.0.4",
    "@logtape/logtape": "^2.0.4",
    "ansis": "^4.2.0",
    "cleye": "^2.3.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/bun": "^1.2.0"
  }
}
